generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Task {
  id        String   @id @default(cuid())
  title     String
  status    String   @default("todo")
  priority  String   @default("medium")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
